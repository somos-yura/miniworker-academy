---
import FeatureCard from './FeatureCard.astro';

interface Feature {
	title: string;
	description: string;
	icon: string;
}

interface Props {
	id?: string;
	title: string;
	titleAccent: string;
	subtitle: string;
	features: Feature[];
}

const { id, title, titleAccent, subtitle, features } = Astro.props;
---

<section class="features-section" id={id}>
	<div class="features-container">
		<h2 class="features-title">
			{title} <span class="features-title-accent">{titleAccent}</span>
		</h2>
		<p class="features-subtitle">{subtitle}</p>

		<div class="features-grid">
			{features.map((feature) => (
				<FeatureCard
					title={feature.title}
					description={feature.description}
					icon={feature.icon}
				/>
			))}
		</div>
	</div>
</section>

<style>
	.features-section {
		background: #ffffff;
		padding: 2rem 3rem 6rem 3rem;
		position: relative;
		margin-top: 2rem;
	}

	.features-container {
		max-width: 1400px;
		margin: 0 auto;
		width: 100%;
	}

	.features-title {
		font-size: 3.5rem;
		font-weight: 700;
		text-align: center;
		color: #1e3a8a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}

	.features-title.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.features-title-accent {
		color: #38bdf8;
	}

	.features-subtitle {
		font-size: 1.25rem;
		text-align: center;
		color: #64748b;
		max-width: 800px;
		margin: 0 auto 4rem auto;
		line-height: 1.7;
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out 0.2s, transform 0.6s ease-out 0.2s;
	}

	.features-subtitle.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	@media (max-width: 1024px) {
		.features-section {
			padding: 1.5rem 2rem 4rem 2rem;
		}

		.features-title {
			font-size: 2.5rem;
		}

		.features-subtitle {
			font-size: 1.125rem;
			margin-bottom: 3rem;
		}

		.features-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}
	}

	@media (max-width: 768px) {
		.features-section {
			padding: 4rem 2rem 5rem 2rem;
		}

		.features-title {
			font-size: 2.5rem;
			margin-bottom: 1.25rem;
		}

		.features-subtitle {
			font-size: 1.125rem;
			margin-bottom: 3rem;
			line-height: 1.65;
		}

		.features-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	@media (max-width: 480px) {
		.features-section {
			padding: 3rem 1.5rem 4rem 1.5rem;
		}

		.features-title {
			font-size: 2rem;
			margin-bottom: 1rem;
		}

		.features-subtitle {
			font-size: 1rem;
			margin-bottom: 2.5rem;
			line-height: 1.6;
		}

		.features-grid {
			gap: 1.75rem;
		}
	}
</style>

