---
import logo from '../assets/miniworkerlogosinbg.svg';
---

<footer class="footer">
	<div class="footer-container">
		<div class="footer-logo">
			<img src={logo.src} alt="Miniworker Academy" />
		</div>
		<p class="footer-tagline">
			Apoyando tu crecimiento en el mundo del desarrollo.
		</p>
		<div class="footer-divider"></div>
		<p class="footer-copyright">
			© 2025 Miniworker Academy. Todos los derechos reservados.
		</p>
	</div>
</footer>

<style>
	.footer {
		background: #ffffff;
		padding: 4rem 3rem 2rem 3rem;
		border-top: 1px solid #e0f2fe;
	}

	.footer-container {
		max-width: 1400px;
		margin: 0 auto;
		text-align: center;
	}

	.footer-logo {
		margin-bottom: 1.5rem;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.footer-logo img {
		max-width: 200px;
		height: auto;
	}

	.footer-tagline {
		font-size: 1.125rem;
		color: #64748b;
		line-height: 1.7;
		margin: 0 auto 2rem auto;
		max-width: 600px;
	}

	.footer-divider {
		width: 100%;
		height: 1px;
		background: #e0f2fe;
		margin: 2rem 0;
	}

	.footer-copyright {
		font-size: 0.875rem;
		color: #94a3b8;
		margin: 0;
	}

	@media (max-width: 768px) {
		.footer {
			padding: 3rem 2rem 1.5rem 2rem;
		}

		.footer-logo img {
			max-width: 150px;
		}

		.footer-tagline {
			font-size: 1rem;
			margin-bottom: 1.5rem;
		}

		.footer-divider {
			margin: 1.5rem 0;
		}

		.footer-copyright {
			font-size: 0.8125rem;
		}
	}

	@media (max-width: 480px) {
		.footer {
			padding: 2.5rem 1.5rem 1.25rem 1.5rem;
		}

		.footer-logo img {
			max-width: 120px;
		}

		.footer-tagline {
			font-size: 0.9375rem;
		}
	}
</style>

