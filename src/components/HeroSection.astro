---
interface Props {
	logo: ImageMetadata;
	badgeText: string;
	headlineStatic: string;
	description: string;
	ctaText: string;
	ctaSubtext: string;
}

const {
	logo,
	badgeText,
	headlineStatic,
	description,
	ctaText,
	ctaSubtext,
} = Astro.props;
---

<div class="hero-container">
	<div class="logo-container">
		<img class="logo" src={logo.src} alt="Miniworker Academy" />
	</div>

	<div class="badge">
		<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
		</svg>
		<span>{badgeText}</span>
	</div>

	<h1 class="headline">
		<span class="headline-static">{headlineStatic}</span>
		<br />
		<span class="headline-animated" id="typedText"></span><span class="cursor" id="cursor">|</span>
	</h1>

	<p class="description">{description}</p>

	<div class="cta-buttons">
		<a href="#waitlist" class="btn btn-secondary">{ctaText}</a>
	</div>
	<p class="cta-subtext">{ctaSubtext}</p>
</div>

<style>
	.hero-container {
		text-align: center;
		max-width: 1400px;
		width: 100%;
		z-index: 1;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		align-items: center;
		gap: 2rem;
	}

	.logo-container {
		margin-bottom: 0;
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
		width: 100%;
		min-height: 200px;
	}

	.logo {
		max-width: 600px;
		width: 100%;
		height: auto;
		transition: opacity 0.3s ease;
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%) scale(0.8);
		opacity: 0;
		animation: logoEntrance 1s ease-out 0.3s forwards;
	}

	@keyframes logoEntrance {
		0% {
			opacity: 0;
			transform: translateX(-50%) scale(0.8) translateY(-20px);
		}
		100% {
			opacity: 1;
			transform: translateX(-50%) scale(1) translateY(0);
		}
	}


	.badge {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		gap: 0.75rem;
		padding: 0.75rem 1.5rem;
		background: #1e293b;
		border: 1px solid #334155;
		border-radius: 2rem;
		color: #38bdf8;
		font-size: 1rem;
		font-weight: 500;
		margin-bottom: 0;
		opacity: 0;
		transform: translateY(-10px);
		animation: fadeInUp 0.6s ease-out 0.6s forwards;
	}

	@keyframes fadeInUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.badge svg {
		width: 18px;
		height: 18px;
	}

	.headline {
		font-size: 5rem;
		font-weight: 700;
		line-height: 1.1;
		margin: 0;
		color: #ffffff;
		opacity: 0;
		transform: translateY(20px);
		animation: fadeInUp 0.8s ease-out 0.9s forwards;
	}

	.headline-static {
		color: #ffffff;
	}

	.headline-animated {
		color: #38bdf8;
		display: inline-block;
		min-height: 1.2em;
	}

	.cursor {
		color: #38bdf8;
		animation: blink 1s infinite;
		margin-left: 0;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	.description {
		font-size: 1.25rem;
		line-height: 1.7;
		color: #cbd5e1;
		margin: 0;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
		opacity: 0;
		transform: translateY(20px);
		animation: fadeInUp 0.8s ease-out 1.1s forwards;
	}

	.cta-buttons {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
		flex-wrap: wrap;
		margin: 0;
		opacity: 0;
		transform: translateY(20px);
		animation: fadeInUp 0.8s ease-out 1.3s forwards;
	}

	.cta-subtext {
		font-size: 1.125rem;
		color: #38bdf8;
		text-align: center;
		line-height: 1.5;
		padding: 0;
		margin-top: -15px;
	}

	.btn {
		padding: 1.125rem 2.5rem;
		border-radius: 0.875rem;
		font-size: 1.125rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
		border: none;
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-family: inherit;
		text-decoration: none;
		white-space: nowrap;
	}

	.btn-secondary {
		background: #1e293b;
		color: #38bdf8;
		border: 1px solid #38bdf8;
	}

	.btn-secondary:hover {
		background: #38bdf8;
		color: #0f172a;
	}

	@media (max-width: 1024px) {
		.hero-container {
			max-width: 100%;
			gap: 1.75rem;
		}

		.logo {
			max-width: 500px;
		}

		.headline {
			font-size: 3.5rem;
		}

		.description {
			font-size: 1.125rem;
			max-width: 100%;
		}

		.badge {
			font-size: 0.9375rem;
			padding: 0.625rem 1.25rem;
		}
	}

	@media (max-width: 768px) {
		.hero-container {
			gap: 2rem;
		}

		.logo-container {
			min-height: 180px;
		}

		.logo {
			max-width: 400px;
		}

		.headline {
			font-size: 3rem;
			line-height: 1.15;
		}

		.description {
			font-size: 1.125rem;
			line-height: 1.7;
			max-width: 100%;
		}

		.badge {
			font-size: 0.9375rem;
			padding: 0.625rem 1.25rem;
			gap: 0.625rem;
		}

		.badge svg {
			width: 17px;
			height: 17px;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
			gap: 1rem;
			width: 100%;
			max-width: 500px;
		}

		.btn {
			padding: 0.875rem 1.5rem;
			font-size: 1rem;
			width: auto;
			justify-content: center;
		}

		.cta-subtext {
			font-size: 1rem;
			max-width: 500px;
		}
	}

	@media (max-width: 480px) {
		.hero-container {
			gap: 1.75rem;
		}

		.logo-container {
			min-height: 160px;
		}

		.logo {
			max-width: 320px;
		}

		.headline {
			font-size: 2.25rem;
			line-height: 1.2;
		}

		.description {
			font-size: 1rem;
			line-height: 1.65;
		}

		.badge {
			font-size: 0.875rem;
			padding: 0.5625rem 1.125rem;
			gap: 0.5625rem;
		}

		.badge svg {
			width: 16px;
			height: 16px;
		}

		.btn {
			padding: 0.75rem 1.25rem;
			font-size: 0.9375rem;
		}

		.cta-subtext {
			font-size: 0.9375rem;
		}
	}
</style>

