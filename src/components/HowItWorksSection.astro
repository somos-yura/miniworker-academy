---
import StepCard from './StepCard.astro';

interface Step {
	number: string;
	title: string;
	description: string;
	icon: string;
}

interface Props {
	id?: string;
	title: string;
	titleAccent: string;
	subtitle: string;
	steps: Step[];
}

const { id, title, titleAccent, subtitle, steps } = Astro.props;
---

<section class="how-it-works-section" id={id}>
	<div class="how-it-works-container">
		<h2 class="how-it-works-title">
			{title} <span class="how-it-works-title-accent">{titleAccent}</span>
		</h2>
		<p class="how-it-works-subtitle">{subtitle}</p>

		<div class="steps-grid">
			{steps.map((step) => (
				<StepCard
					number={step.number}
					title={step.title}
					description={step.description}
					icon={step.icon}
				/>
			))}
		</div>
	</div>
</section>

<style>
	.how-it-works-section {
		background: #0f172a;
		padding: 6rem 3rem;
		position: relative;
	}

	.how-it-works-container {
		max-width: 1400px;
		margin: 0 auto;
		width: 100%;
	}

	.how-it-works-title {
		font-size: 3.5rem;
		font-weight: 700;
		text-align: center;
		color: #ffffff;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}

	.how-it-works-title.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.how-it-works-title-accent {
		color: #38bdf8;
	}

	.how-it-works-subtitle {
		font-size: 1.25rem;
		text-align: center;
		color: #cbd5e1;
		max-width: 800px;
		margin: 0 auto 4rem auto;
		line-height: 1.7;
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out 0.2s, transform 0.6s ease-out 0.2s;
	}

	.how-it-works-subtitle.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.steps-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		position: relative;
	}

	.steps-grid::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 12.5%;
		right: 12.5%;
		height: 2px;
		background: linear-gradient(to right, transparent, #38bdf8, #38bdf8, transparent);
		opacity: 0.3;
		z-index: 0;
		pointer-events: none;
		transform: translateY(-50%);
	}

	.steps-grid > * {
		position: relative;
		z-index: 1;
	}

	@media (max-width: 1024px) {
		.how-it-works-section {
			padding: 4rem 2rem;
		}

		.how-it-works-title {
			font-size: 2.5rem;
		}

		.how-it-works-subtitle {
			font-size: 1.125rem;
			margin-bottom: 3rem;
		}

		.steps-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem;
		}
	}

	@media (max-width: 768px) {
		.how-it-works-section {
			padding: 4rem 2rem 5rem 2rem;
		}

		.how-it-works-title {
			font-size: 2.5rem;
			margin-bottom: 1.25rem;
		}

		.how-it-works-subtitle {
			font-size: 1.125rem;
			margin-bottom: 3rem;
			line-height: 1.65;
		}

		.steps-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.steps-grid::before {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.how-it-works-section {
			padding: 3rem 1.5rem 4rem 1.5rem;
		}

		.how-it-works-title {
			font-size: 2rem;
			margin-bottom: 1rem;
		}

		.how-it-works-subtitle {
			font-size: 1rem;
			margin-bottom: 2.5rem;
			line-height: 1.6;
		}

		.steps-grid {
			gap: 1.75rem;
		}
	}
</style>

