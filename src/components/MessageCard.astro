---
interface Props {
	message: string;
	name: string;
	role: string;
	avatar?: string;
}

const { message, name, role, avatar } = Astro.props;
---

<div class="message-card">
	<div class="message-header">
		{avatar ? (
			<img class="message-avatar" src={avatar} alt={name} />
		) : (
			<div class="message-avatar-placeholder">
				{name.includes('Yura') ? (
					<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect x="2" y="4" width="20" height="16" rx="2"></rect>
						<path d="M6 8h12"></path>
						<path d="M6 12h12"></path>
						<path d="M6 16h8"></path>
					</svg>
				) : (
					<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
						<circle cx="12" cy="7" r="4"></circle>
					</svg>
				)}
			</div>
		)}
		<div class="message-info">
			<p class="message-name">{name}</p>
			<p class="message-role">{role}</p>
		</div>
	</div>
	<div class="message-content">{message}</div>
</div>

<style>
	.message-card {
		background: #ffffff;
		border: 1px solid #e0f2fe;
		border-radius: 1rem;
		padding: 2.5rem;
		width: 100%;
		margin: 0;
		transition: all 0.3s ease;
		flex-shrink: 0;
		box-sizing: border-box;
		height: auto;
	}

	.message-card:hover {
		box-shadow: 0 8px 24px rgba(56, 189, 248, 0.1);
		border-color: #38bdf8;
	}

	.message-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid #e0f2fe;
	}

	.message-avatar,
	.message-avatar-placeholder {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.message-avatar {
		object-fit: cover;
	}

	.message-avatar-placeholder {
		background: rgba(56, 189, 248, 0.1);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #38bdf8;
	}

	.message-info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.message-name {
		font-size: 1rem;
		font-weight: 700;
		color: #1e3a8a;
		margin: 0;
	}

	.message-role {
		font-size: 0.875rem;
		color: #64748b;
		margin: 0;
	}

	.message-content {
		font-size: 1.125rem;
		line-height: 1.7;
		color: #1e3a8a;
		margin: 0;
	}

	@media (max-width: 768px) {
		.message-card {
			padding: 1.5rem;
		}

		.message-header {
			margin-bottom: 1rem;
			padding-bottom: 0.75rem;
			gap: 0.75rem;
		}

		.message-avatar,
		.message-avatar-placeholder {
			width: 40px;
			height: 40px;
		}

		.message-avatar-placeholder svg {
			width: 20px;
			height: 20px;
		}

		.message-content {
			font-size: 0.9375rem;
			line-height: 1.6;
		}

		.message-name {
			font-size: 0.9375rem;
		}

		.message-role {
			font-size: 0.8125rem;
		}
	}

	@media (max-width: 480px) {
		.message-card {
			padding: 1.25rem;
		}

		.message-header {
			margin-bottom: 0.875rem;
			padding-bottom: 0.625rem;
			gap: 0.625rem;
		}

		.message-avatar,
		.message-avatar-placeholder {
			width: 36px;
			height: 36px;
		}

		.message-avatar-placeholder svg {
			width: 18px;
			height: 18px;
		}

		.message-content {
			font-size: 0.875rem;
			line-height: 1.55;
		}

		.message-name {
			font-size: 0.875rem;
		}

		.message-role {
			font-size: 0.75rem;
		}
	}
</style>

